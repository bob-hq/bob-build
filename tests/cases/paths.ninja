# This file was automatically generated by Bob.
builddir = build/.bob
build build/.bob/always: phony

rule bob-1
  command = echo hi > $out

build build/somewhere/in-somewhere: bob-1
build build/somewhere/deeper/in-deeper: bob-1
build build/another/in-another: bob-1
build build/resolve-src: bob-1 $root/tests/cases/inside/deep/in-deep $root/tests/cases/inside/deep/another-in-deep
build build/resolve-src-outside: bob-1 $root/tests/cases/outside
rule configure-bob-2
  command = FORCE_COLOR=1 $bobbin configure --use-current-configs -f $bobfile
  description = CONFIGURE $out
  generator = 1
  pool = console

build build/.bob/build.ninja: configure-bob-2 | $root/tests/cases/paths.bob build/.bob/configs.json
  bobbin = $root/.venv/bin/python -m bob
  bobfile = $root/tests/cases/paths.bob
