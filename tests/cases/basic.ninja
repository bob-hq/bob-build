# This file was automatically generated by Bob.
builddir = build/.bob
build build/.bob/always: phony

rule bob-1
  command = echo hi > $out

build build/hi: bob-1
build hola: phony build/hi
rule shelloutput-bob-2
  command = ((cat magic) > $out.new && cmp -s $out $out.new || mv $out.new $out); rm -f $out.new
  description = SHELL OUTPUT $out
  restat = 1

build build/magic: shelloutput-bob-2 | build/.bob/always
rule configure-bob-3
  command = FORCE_COLOR=1 $bobbin configure --use-current-configs -f $bobfile
  description = CONFIGURE $out
  generator = 1
  pool = console

build build/.bob/build.ninja: configure-bob-3 | $root/tests/cases/basic.bob build/.bob/configs.json
  bobbin = $root/.venv/bin/python -m bob
  bobfile = $root/tests/cases/basic.bob
