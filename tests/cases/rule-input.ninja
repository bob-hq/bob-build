# This file was automatically generated by Bob.
builddir = build/.bob

rule bob-1
  command = echo hi > $out

build build/hi: bob-1
rule bob-2
  command = cp $in $out

build build/bye: bob-2 build/hi
build build/byebye: bob-2 build/hi
rule configure-bob-3
  command = FORCE_COLOR=1 $bobbin configure --use-current-configs -f $bobfile
  description = CONFIGURE $out
  generator = 1
  pool = console

build build/.bob/build.ninja: configure-bob-3 | $root/tests/cases/rule-input.bob build/.bob/configs.json
  bobbin = $root/.venv/bin/python -m bob
  bobfile = $root/tests/cases/rule-input.bob
